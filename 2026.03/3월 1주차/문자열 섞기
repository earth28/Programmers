class Solution {
    public String solution(String str1, String str2) {
        String answer = "";
        
        for (int i = 0; i < str1.length(); i++) {  # 반복문 사용하여 각 문자열로부터 문자 하나씩 가져오기
            answer += str1.charAt(i);
            answer += str2.charAt(i);    
        }
        
        return answer;
    }
}
